permissions:
  default: ask
jinx_name: "compress"
description: "Compact conversation context using breathe(). Summarizes the session into a plan and starts a new linked conversation."
inputs: []
steps:
  - name: "compress_conversation"
    engine: "python"
    code: |
      import os
      import traceback
      from npcpy.llm_funcs import breathe
      from npcpy.memory.command_history import CommandHistory, start_new_conversation, save_conversation_message

      output_messages = context.get('messages', [])
      current_npc = context.get('npc')
      team_obj = context.get('team')

      # Use the shell's current model/provider — NEVER let the LLM override these.
      m = None
      p = None
      try:
          m = state.chat_model
          p = state.chat_provider
      except Exception:
          pass
      if not m and current_npc and hasattr(current_npc, 'model') and current_npc.model:
          m = current_npc.model
      if not p and current_npc and hasattr(current_npc, 'provider') and current_npc.provider:
          p = current_npc.provider

      try:
          result = breathe(messages=output_messages, model=m, provider=p, npc=current_npc)
          summary = result.get('output', 'Context compressed.') if isinstance(result, dict) else str(result)
      except Exception as e:
          traceback.print_exc()
          context['output'] = "Error during compression: " + str(e)
          exit()

      # Start new linked conversation
      old_cid = state.conversation_id if state else None
      last_msg_id = None
      ch = None
      try:
          db_path = os.getenv("NPCSH_DB_PATH", os.path.expanduser("~/npcsh_history.db"))
          ch = CommandHistory(db_path)
          if old_cid:
              last_msg_id = ch.get_last_message_id(old_cid)

          new_cid = start_new_conversation()
          if state:
              state.conversation_id = new_cid

          summary_content = "Session context (continued from " + str(old_cid) + "): " + summary
          recent = list(output_messages[-6:])
          context['messages'] = [{"role": "system", "content": summary_content}] + recent

          npc_name = current_npc.name if current_npc else "npcsh"
          team_name = team_obj.name if team_obj else "npcsh"
          save_conversation_message(
              ch, new_cid, "system", summary_content,
              npc=npc_name, team=team_name,
              parent_message_id=last_msg_id,
          )
      finally:
          if ch:
              ch.close()

      link_info = " (linked via " + str(last_msg_id) + ")" if last_msg_id else ""
      context['output'] = "Compressed. New conversation: " + str(state.conversation_id if state else new_cid) + link_info
