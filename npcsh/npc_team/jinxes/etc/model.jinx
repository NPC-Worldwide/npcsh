jinx_name: model
description: Set the active chat model/provider from available options (provider-first browser)
inputs: []
steps:
  - name: model_browser
    engine: python
    code: |
      import os
      import sys
      try:
          import tty
          import termios
      except ImportError:
          tty = None
          termios = None
      import select

      if not sys.stdin.isatty():
          context['output'] = "Model TUI requires an interactive terminal."
      else:
          import shutil
          from collections import defaultdict
          from npcpy.npc_sysenv import get_locally_available_models
          from npcpy.npc_compiler import _is_cli_provider
          from npcsh.config import set_npcsh_config_value

          LOCAL_PROVIDERS = {'ollama', 'llamacpp', 'lmstudio', 'mlx', 'lora'}
          CLOUD_PROVIDERS = set()

          _CLI_BINARY = {
              'claude_code': 'claude',
              'claude':      'claude',
              'opencode':    'opencode',
              'codex':       'codex',
              'amp':         'amp',
              'gemini':      'gemini',
              'aider':       'aider',
              'kimi':        'kimi',
              'kimi_code':   'kimi',
              'kilo':        'kilo',
          }

          def _try_list_cli_models(provider, binary):
              import subprocess, json as _json
              try:
                  if provider == 'opencode':
                      r = subprocess.run(['opencode', 'models'], capture_output=True, text=True, timeout=15)
                      if r.returncode == 0:
                          return [l.strip() for l in r.stdout.splitlines() if l.strip()]
                  elif provider == 'codex':
                      r = subprocess.run(['codex', 'debug', 'models'], capture_output=True, text=True, timeout=15)
                      if r.returncode == 0:
                          data = _json.loads(r.stdout)
                          items = data if isinstance(data, list) else data.get('data', data.get('models', []))
                          return [m['id'] if isinstance(m, dict) else str(m) for m in items if m]
                  elif provider == 'kilo':
                      r = subprocess.run(['kilo', 'models'], capture_output=True, text=True, timeout=15)
                      if r.returncode == 0:
                          return [l.split()[0] for l in r.stdout.splitlines() if l.strip() and not l.startswith('#')]
              except Exception:
                  pass
              return []

          class TUIState:
              def __init__(self):
                  self.sel = 0               # selected index in current level
                  self.scroll = 0            # scroll offset in current level
                  self.status = ""
                  self.providers = []        # list of provider names
                  self.provider_models = {}  # provider -> list of model_ids
                  self.expanded = set()      # expanded provider names
                  self.level = 'providers'   # 'providers' or 'models'
                  self.active_provider = ''
                  self.chat_model = ''
                  self.chat_provider = ''

          ui = TUIState()

          def term_size():
              try:
                  s = os.get_terminal_size()
                  return s.columns, s.lines
              except:
                  return 80, 24

          def load_active():
              ui.chat_model = os.environ.get('NPCSH_CHAT_MODEL', '')
              ui.chat_provider = os.environ.get('NPCSH_CHAT_PROVIDER', '')

          def detect_models():
              ui.status = "Detecting models..."
              raw_models = []
              try:
                  models_dict = get_locally_available_models('.', airplane_mode=False)
              except Exception as e:
                  models_dict = {}
                  ui.status = f"Detection error: {e}"

              if models_dict:
                  for model_id, provider in models_dict.items():
                      raw_models.append((provider, model_id))

              # CLI providers
              _CLI_SUPPORTED = {'claude_code', 'opencode', 'codex', 'kimi_code', 'kilo'}
              for provider in sorted(_CLI_SUPPORTED):
                  binary = _CLI_BINARY.get(provider, provider.replace('_code', ''))
                  if shutil.which(binary) is None:
                      continue
                  models = _try_list_cli_models(provider, binary)
                  if models:
                      for model_id in models:
                          raw_models.append((provider, model_id))
                  else:
                      raw_models.append((provider, binary))

              # Cloud providers from litellm env discovery
              try:
                  from litellm import utils as _litellm_utils, get_valid_models as _litellm_get_models
                  available = _litellm_utils._infer_valid_provider_from_env_vars()
                  for p in available:
                      prov = p.value
                      CLOUD_PROVIDERS.add(prov)
                      try:
                          models = _litellm_get_models(custom_llm_provider=prov)
                          if models:
                              for m in models[:20]:
                                  raw_models.append((prov, m))
                          else:
                              raw_models.append((prov, prov))
                      except Exception:
                          raw_models.append((prov, prov))
              except Exception:
                  pass

              # Group by provider
              grouped = defaultdict(list)
              for prov, model in raw_models:
                  grouped[prov].append(model)

              # Sort providers: local first, then cli, then cloud
              def _provider_sort_key(p):
                  if p in LOCAL_PROVIDERS:
                      return (0, p)
                  if _is_cli_provider(p):
                      return (1, p)
                  return (2, p)

              ui.providers = sorted(grouped.keys(), key=_provider_sort_key)
              ui.provider_models = {p: sorted(set(grouped[p])) for p in ui.providers}

              if ui.providers and not ui.status.startswith("Detection error"):
                  total = sum(len(v) for v in ui.provider_models.values())
                  ui.status = f"Found {len(ui.providers)} providers, {total} models"

          def is_active(provider, model_id):
              return model_id == ui.chat_model and provider == ui.chat_provider

          def wline(row, text):
              return f"\033[{row};1H\033[K{text}"

          def _provider_color(provider):
              if _is_cli_provider(provider):
                  return "\033[33m"
              if provider in LOCAL_PROVIDERS:
                  return "\033[36m"
              return "\033[35m"

          def _provider_icon(provider):
              if _is_cli_provider(provider):
                  return "[CLI]"
              if provider in LOCAL_PROVIDERS:
                  return "[LOC]"
              return "[CLD]"

          def render():
              W, H = term_size()
              out = []
              out.append("\033[H")

              # header
              hdr = " Set Chat Model "
              pad = '=' * W
              out.append(wline(1, f"\033[7;1m{pad}\033[0m"))
              out.append(f"\033[1;{max(1,(W - len(hdr)) // 2)}H\033[7;1m{hdr}\033[0m")
              out.append(wline(2, f"\033[90m{'─' * W}\033[0m"))

              # breadcrumb / status
              if ui.level == 'providers':
                  breadcrumb = "  Providers"
              else:
                  breadcrumb = f"  {_provider_icon(ui.active_provider)} {ui.active_provider} → Models"
              if ui.status:
                  breadcrumb += f"  |  {ui.status}"
              out.append(wline(3, f"\033[1m{breadcrumb[:W]}\033[0m"))

              # body
              body_start = 4
              body_end = H - 3
              body_h = body_end - body_start + 1

              if ui.level == 'providers':
                  items = ui.providers
                  for r in range(body_h):
                      row = body_start + r
                      idx = r + ui.scroll
                      if idx >= len(items):
                          out.append(wline(row, ""))
                          continue
                      provider = items[idx]
                      model_count = len(ui.provider_models.get(provider, []))
                      expanded = provider in ui.expanded
                      icon = _provider_icon(provider)
                      color = _provider_color(provider)
                      caret = "▼" if expanded else "▶"
                      line_text = f"  {caret} {icon} {provider}  ({model_count} models)"

                      if idx == ui.sel:
                          out.append(wline(row, f"\033[7m> {line_text[:W-2].ljust(W-2)}\033[0m"))
                      else:
                          out.append(wline(row, f"  {color}{line_text[:W]}\033[0m"))

                  if not items:
                      out.append(wline(body_start, "  \033[90mNo providers found. Press [d] to refresh.\033[0m"))

              else:  # models level
                  models = ui.provider_models.get(ui.active_provider, [])
                  for r in range(body_h):
                      row = body_start + r
                      idx = r + ui.scroll
                      if idx >= len(models):
                          out.append(wline(row, ""))
                          continue
                      model_id = models[idx]
                      active = is_active(ui.active_provider, model_id)
                      marker = " > " if active else "   "
                      disp = model_id if len(model_id) <= W - 10 else model_id[:W-13] + '...'
                      line_text = f"{marker}{disp}"
                      if idx == ui.sel:
                          out.append(wline(row, f"\033[7m{line_text[:W].ljust(W)}\033[0m"))
                      else:
                          prefix = "  * " if active else "    "
                          out.append(wline(row, f"{prefix}{disp}"))

              # separator + footer
              out.append(wline(H - 2, f"\033[90m{'─' * W}\033[0m"))

              # active model line
              if ui.chat_model:
                  active_line = f" Active: {ui.chat_model} / {ui.chat_provider}"
                  out.append(wline(H - 1, f" \033[33m{active_line[:W-2]}\033[0m"))
              else:
                  out.append(wline(H - 1, " \033[90mNo active model set.\033[0m"))

              # controls
              if ui.level == 'providers':
                  foot = " [j/k] Nav  [Enter/l] Expand  [q] Quit  [d] Refresh"
              else:
                  foot = " [j/k] Nav  [Enter] Set  [h/Esc] Back  [q] Quit"
              out.append(wline(H, f"\033[7m{foot[:W].ljust(W)}\033[0m"))

              sys.stdout.write(''.join(out))
              sys.stdout.flush()

          def handle(c):
              if c == '\x1b':
                  return handle_esc()
              if c == 'q':
                  return False
              elif c == '\r' or c == '\n':
                  handle_enter()
              elif c == 'k':
                  nav_up()
              elif c == 'j':
                  nav_down()
              elif c == 'h':
                  go_back()
              elif c == 'l':
                  expand_or_enter()
              elif c == 'd':
                  detect_models()
                  load_active()
              return True

          def handle_esc():
              if select.select([fd], [], [], 0.05)[0]:
                  c2 = os.read(fd, 1).decode('latin-1')
                  if c2 == '[':
                      c3 = os.read(fd, 1).decode('latin-1')
                      if c3 == 'A':
                          nav_up()
                      elif c3 == 'B':
                          nav_down()
                  elif c2 == '\x7f':  # some terminals send ESC + DEL for backspace
                      go_back()
              else:
                  #裸 ESC = go back
                  go_back()
              return True

          def nav_up():
              ui.sel = max(0, ui.sel - 1)
              if ui.sel < ui.scroll:
                  ui.scroll = ui.sel
              ui.status = ""

          def nav_down():
              _, H = term_size()
              body_h = H - 7
              items = _current_items()
              mx = max(0, len(items) - 1)
              ui.sel = min(mx, ui.sel + 1)
              if ui.sel >= ui.scroll + body_h:
                  ui.scroll = ui.sel - body_h + 1
              ui.status = ""

          def _current_items():
              if ui.level == 'providers':
                  return ui.providers
              return ui.provider_models.get(ui.active_provider, [])

          def expand_or_enter():
              if ui.level == 'providers':
                  if not ui.providers or ui.sel >= len(ui.providers):
                      return
                  provider = ui.providers[ui.sel]
                  models = ui.provider_models.get(provider, [])
                  if not models:
                      ui.status = f"{provider} has no models."
                      return
                  # toggle expand vs enter
                  if provider in ui.expanded:
                      # enter model selection
                      ui.level = 'models'
                      ui.active_provider = provider
                      ui.sel = 0
                      ui.scroll = 0
                  else:
                      ui.expanded.add(provider)

          def handle_enter():
              if ui.level == 'providers':
                  expand_or_enter()
              else:
                  set_selected()

          def go_back():
              if ui.level == 'models':
                  ui.level = 'providers'
                  if ui.active_provider in ui.providers:
                      ui.sel = ui.providers.index(ui.active_provider)
                  else:
                      ui.sel = 0
                  ui.scroll = max(0, ui.sel - 5)
              else:
                  # at top level, ESC/Backspace = quit
                  pass

          def set_selected():
              if ui.level != 'models':
                  return
              models = ui.provider_models.get(ui.active_provider, [])
              if not models or ui.sel >= len(models):
                  ui.status = "No model selected."
                  return
              model_id = models[ui.sel]
              provider = ui.active_provider
              set_npcsh_config_value('NPCSH_CHAT_MODEL', model_id)
              set_npcsh_config_value('NPCSH_CHAT_PROVIDER', provider)
              os.environ['NPCSH_CHAT_MODEL'] = model_id
              os.environ['NPCSH_CHAT_PROVIDER'] = provider
              try:
                  state.chat_model = model_id
                  state.chat_provider = provider
                  if state.npc is not None:
                      state.npc.model = model_id
                      state.npc.provider = provider
              except Exception:
                  pass
              ui.chat_model = model_id
              ui.chat_provider = provider
              ui.status = f"Set to {model_id} / {provider}"

          # main loop
          load_active()
          detect_models()
          fd = sys.stdin.fileno()
          old_attrs = termios.tcgetattr(fd)

          try:
              tty.setcbreak(fd)
              sys.stdout.write('\033[?25l')
              sys.stdout.write('\033[2J\033[H')
              sys.stdout.flush()
              render()
              while True:
                  c = os.read(fd, 1).decode('latin-1')
                  if not handle(c):
                      break
                  render()
          finally:
              termios.tcsetattr(fd, termios.TCSADRAIN, old_attrs)
              sys.stdout.write('\033[?25h\033[2J\033[H')
              sys.stdout.flush()

          context['output'] = f"Chat model: {ui.chat_model} / {ui.chat_provider}" if ui.chat_model else "Model TUI closed."
