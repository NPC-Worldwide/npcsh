jinx_name: models
description: Set the active chat model/provider from available options
inputs: []
steps:
  - name: model_browser
    engine: python
    code: |
      import os
      import sys
      try:
          import tty
          import termios
      except ImportError:
          tty = None
          termios = None
      import select

      if not sys.stdin.isatty():
          context['output'] = "Models TUI requires an interactive terminal."
      else:
          import shutil
          from npcpy.npc_sysenv import get_locally_available_models
          from npcpy.npc_compiler import _is_cli_provider
          from npcsh.config import set_npcsh_config_value

          LOCAL_PROVIDERS = {'ollama', 'llamacpp', 'lmstudio', 'mlx', 'lora'}
          CLOUD_PROVIDERS = {'openai', 'anthropic', 'gemini', 'deepseek'}

          _CLI_BINARY = {
              'claude_code': 'claude',
              'claude':      'claude',
              'opencode':    'opencode',
              'codex':       'codex',
              'amp':         'amp',
              'gemini':      'gemini',
              'aider':       'aider',
              'kimi':        'kimi',
              'kimi_code':   'kimi',
              'kilo':        'kilo',
          }

          def _try_list_cli_models(provider, binary):
              import subprocess, json as _json
              try:
                  if provider == 'opencode':
                      r = subprocess.run(['opencode', 'models'], capture_output=True, text=True, timeout=15)
                      if r.returncode == 0:
                          return [l.strip() for l in r.stdout.splitlines() if l.strip()]
                  elif provider == 'codex':
                      r = subprocess.run(['codex', 'debug', 'models'], capture_output=True, text=True, timeout=15)
                      if r.returncode == 0:
                          data = _json.loads(r.stdout)
                          items = data if isinstance(data, list) else data.get('data', data.get('models', []))
                          return [m['id'] if isinstance(m, dict) else str(m) for m in items if m]
                  elif provider == 'kilo':
                      r = subprocess.run(['kilo', 'models'], capture_output=True, text=True, timeout=15)
                      if r.returncode == 0:
                          return [l.split()[0] for l in r.stdout.splitlines() if l.strip() and not l.startswith('#')]
              except Exception:
                  pass
              return []

          class TUIState:
              def __init__(self):
                  self.sel = 0
                  self.scroll = 0
                  self.status = ""
                  self.models = []       # list of (provider, model_id)
                  self.chat_model = ''
                  self.chat_provider = ''

          ui = TUIState()

          def term_size():
              try:
                  s = os.get_terminal_size()
                  return s.columns, s.lines
              except:
                  return 80, 24

          def load_active():
              ui.chat_model = os.environ.get('NPCSH_CHAT_MODEL', '')
              ui.chat_provider = os.environ.get('NPCSH_CHAT_PROVIDER', '')

          def detect_models():
              ui.status = "Detecting models..."
              try:
                  models_dict = get_locally_available_models('.', airplane_mode=False)
              except Exception as e:
                  models_dict = {}
                  ui.status = f"Detection error: {e}"
              ui.models = []
              if models_dict:
                  for model_id, provider in sorted(models_dict.items(), key=lambda x: (x[1], x[0])):
                      ui.models.append((provider, model_id))
              # CLI providers
              _CLI_SUPPORTED = {'claude_code', 'opencode', 'codex', 'kimi_code', 'kilo'}
              for provider in sorted(_CLI_SUPPORTED):
                  binary = _CLI_BINARY.get(provider, provider.replace('_code', ''))
                  if shutil.which(binary) is None:
                      continue
                  models = _try_list_cli_models(provider, binary)
                  if models:
                      for model_id in models:
                          ui.models.append((provider, model_id))
                  else:
                      ui.models.append((provider, binary))
              if ui.models and not ui.status.startswith("Detection error"):
                  ui.status = f"Found {len(ui.models)} models"

          def is_active(provider, model_id):
              return model_id == ui.chat_model and provider == ui.chat_provider

          def wline(row, text):
              return f"\033[{row};1H\033[K{text}"

          def render():
              W, H = term_size()
              out = []
              out.append("\033[H")

              # header
              hdr = " Set Chat Model "
              pad = '=' * W
              out.append(wline(1, f"\033[7;1m{pad}\033[0m"))
              out.append(f"\033[1;{max(1,(W - len(hdr)) // 2)}H\033[7;1m{hdr}\033[0m")
              out.append(wline(2, f"\033[90m{'─' * W}\033[0m"))

              # column header
              prov_w = 14
              model_w = max(24, W - prov_w - 10)
              col_hdr = f"   {'Provider':<{prov_w}}{'Model':<{model_w}}"
              out.append(wline(3, f"\033[1m{col_hdr[:W]}\033[0m"))

              # body
              body_start = 4
              body_end = H - 3
              body_h = body_end - body_start + 1

              vis = ui.models[ui.scroll:ui.scroll + body_h]
              for r in range(body_h):
                  row = body_start + r
                  idx = r + ui.scroll
                  if r >= len(vis):
                      out.append(wline(row, ""))
                      continue
                  provider, model_id = vis[r]
                  active = is_active(provider, model_id)
                  disp_model = model_id
                  if len(disp_model) > model_w - 1:
                      disp_model = disp_model[:model_w - 4] + '...'

                  if idx == ui.sel:
                      marker = " > " if not active else " >*"
                      line_sel = f"{marker}{provider:<{prov_w}}{disp_model:<{model_w}}"
                      out.append(wline(row, f"\033[7m{line_sel[:W].ljust(W)}\033[0m"))
                  else:
                      if _is_cli_provider(provider):
                          prov_color = "\033[33m"
                      elif provider in LOCAL_PROVIDERS:
                          prov_color = "\033[36m"
                      else:
                          prov_color = "\033[35m"
                      marker = "   " if not active else "  * "
                      line_fmt = f"{marker}{prov_color}{provider:<{prov_w}}\033[0m{disp_model:<{model_w}}"
                      out.append(wline(row, line_fmt))

              if not ui.models:
                  out.append(wline(body_start, "  \033[90mNo models found. Press [d] to refresh.\033[0m"))

              # separator + footer
              out.append(wline(H - 2, f"\033[90m{'─' * W}\033[0m"))

              # active model line
              if ui.chat_model:
                  active_line = f" Active: {ui.chat_model} / {ui.chat_provider}"
                  out.append(wline(H - 1, f" \033[33m{active_line[:W-2]}\033[0m"))
              else:
                  out.append(wline(H - 1, " \033[90mNo active model set.\033[0m"))

              # controls
              foot = " [j/k] Nav  [Enter] Set  [d] Refresh  [q] Quit"
              out.append(wline(H, f"\033[7m{foot[:W].ljust(W)}\033[0m"))

              sys.stdout.write(''.join(out))
              sys.stdout.flush()

          def handle(c):
              if c == '\x1b':
                  return handle_esc()
              if c == 'q':
                  return False
              elif c == '\r' or c == '\n':
                  set_selected()
              elif c == 'k':
                  nav_up()
              elif c == 'j':
                  nav_down()
              elif c == 'd':
                  detect_models()
                  load_active()
              return True

          def handle_esc():
              if select.select([fd], [], [], 0.05)[0]:
                  c2 = os.read(fd, 1).decode('latin-1')
                  if c2 == '[':
                      c3 = os.read(fd, 1).decode('latin-1')
                      if c3 == 'A':
                          nav_up()
                      elif c3 == 'B':
                          nav_down()
              else:
                  return False
              return True

          def nav_up():
              ui.sel = max(0, ui.sel - 1)
              if ui.sel < ui.scroll:
                  ui.scroll = ui.sel
              ui.status = ""

          def nav_down():
              _, H = term_size()
              body_h = H - 7
              mx = max(0, len(ui.models) - 1)
              ui.sel = min(mx, ui.sel + 1)
              if ui.sel >= ui.scroll + body_h:
                  ui.scroll = ui.sel - body_h + 1
              ui.status = ""

          def set_selected():
              if not ui.models:
                  ui.status = "No models available."
                  return
              if ui.sel >= len(ui.models):
                  ui.status = "No model selected."
                  return
              provider, model_id = ui.models[ui.sel]
              set_npcsh_config_value('NPCSH_CHAT_MODEL', model_id)
              set_npcsh_config_value('NPCSH_CHAT_PROVIDER', provider)
              os.environ['NPCSH_CHAT_MODEL'] = model_id
              os.environ['NPCSH_CHAT_PROVIDER'] = provider
              # Also update the running shell state so it takes effect immediately
              try:
                  state.chat_model = model_id
                  state.chat_provider = provider
              except Exception:
                  pass
              ui.chat_model = model_id
              ui.chat_provider = provider
              ui.status = f"Chat model set to {model_id} / {provider}"

          # main loop
          load_active()
          detect_models()
          fd = sys.stdin.fileno()
          old_attrs = termios.tcgetattr(fd)

          try:
              tty.setcbreak(fd)
              sys.stdout.write('\033[?25l')
              sys.stdout.write('\033[2J\033[H')
              sys.stdout.flush()
              render()
              while True:
                  c = os.read(fd, 1).decode('latin-1')
                  if not handle(c):
                      break
                  render()
          finally:
              termios.tcsetattr(fd, termios.TCSADRAIN, old_attrs)
              sys.stdout.write('\033[?25h\033[2J\033[H')
              sys.stdout.flush()

          context['output'] = f"Chat model: {ui.chat_model} / {ui.chat_provider}" if ui.chat_model else "Models TUI closed."
