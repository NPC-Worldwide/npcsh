permissions:
  default: ask
jinx_name: gen_image
description: Generate an image from a text prompt. Uses NPCSH_IMAGE_GEN_MODEL and NPCSH_IMAGE_GEN_PROVIDER from env by default. Supports ollama, diffusers, openai, gemini.
inputs:
- prompt
- output_name: null
- model: null
- provider: null
- n_images: 1
- width: null
- height: null
- attachments: null
steps:
  - name: generate
    engine: python
    code: |
      import os
      from datetime import datetime
      from npcpy.llm_funcs import gen_image

      image_prompt = str(context.get('prompt', '')).strip()
      output_name = str(context.get('output_name', '') or '').strip()
      model = context.get('model') or os.getenv('NPCSH_IMAGE_GEN_MODEL', 'x/z-image-turbo')
      provider = context.get('provider') or os.getenv('NPCSH_IMAGE_GEN_PROVIDER', 'ollama')
      n_images = 1
      try:
          n_images = max(1, int(context.get('n_images', 1)))
      except Exception:
          pass
      width = None
      try:
          width = int(context.get('width')) if context.get('width') else None
      except Exception:
          pass
      height = None
      try:
          height = int(context.get('height')) if context.get('height') else None
      except Exception:
          pass

      input_images = None
      attachments = str(context.get('attachments', '') or '').strip()
      if attachments:
          input_images = [p.strip() for p in attachments.split(',')]

      if not image_prompt:
          context['output'] = "Error: prompt is required"
      else:
          img_dir = os.path.expanduser("~/.npcsh/images/")
          os.makedirs(img_dir, exist_ok=True)

          kwargs = {
              'model': model,
              'provider': provider,
              'npc': npc if npc and not isinstance(npc, str) else None,
              'n_images': n_images,
          }
          if width:
              kwargs['width'] = width
          if height:
              kwargs['height'] = height
          if input_images:
              kwargs['input_images'] = input_images

          images_list = None
          try:
              images_list = gen_image(image_prompt, **kwargs)
          except Exception as e:
              import traceback
              traceback.print_exc()
              context['output'] = f"Error generating image: {e}"

          if images_list is not None:
              if not isinstance(images_list, list):
                  images_list = [images_list]

              saved_files = []
              for i, image in enumerate(images_list):
                  if image is None:
                      continue
                  if output_name:
                      base = output_name.rsplit('.', 1)[0]
                      current_output_file = f"{base}.png" if len(images_list) == 1 else f"{base}_{i}.png"
                  else:
                      ts = datetime.now().strftime('%Y%m%d_%H%M%S')
                      current_output_file = os.path.join(img_dir, f"image_{ts}_{i}.png")

                  image.save(current_output_file)
                  saved_files.append(current_output_file)

              if saved_files:
                  for f in saved_files:
                      try:
                          subprocess.Popen(['xdg-open', f], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                      except Exception:
                          pass
                  context['output'] = f"Generated: {', '.join(saved_files)}"
              else:
                  context['output'] = "No images generated."
          elif not context.get('output'):
              context['output'] = "No images generated."
