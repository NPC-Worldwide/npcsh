permissions:
  default: ask
jinx_name: loop_plan
description: |
  Scope-lock and execute a multi-step task. Proposes a plan (optionally asking
  the user), then runs an agentic loop using the available jinxes and NPCs.
  Reports progress, enforces action budgets, checkpoints results, and only finishes
  when the work is verified or the user is asked how to proceed.
inputs:
  - goal: null
  - max_iterations: "10"
  - budget_actions: "20"
  - require_confirmation: "false"
steps:
  - name: run_loop_plan
    engine: python
    code: |
      import json
      import os
      import sys
      import traceback
      from datetime import datetime

      from termcolor import colored
      from npcpy.llm_funcs import get_llm_response
      from npcpy.npc_compiler import NPC

      # ── Inputs ─────────────────────────────────────────────────────────────────
      _npc = context.get('npc')
      _team = context.get('team')
      _messages = context.get('messages', [])
      _state = context.get('state')

      goal = context.get('goal', '')
      if not goal:
          context['output'] = "Error: provide a goal=\"...\" for loop_plan."
          context['messages'] = _messages
          exit()

      max_iters = int(context.get('max_iterations') or '10')
      budget_actions = int(context.get('budget_actions') or '20')
      require_confirmation = str(context.get('require_confirmation', 'false')).lower() in ('true', '1', 'yes')

      # Resolve model/provider from state or the invoking NPC.
      _model = None
      _provider = None
      try:
          _model = _state.chat_model
          _provider = _state.chat_provider
      except Exception:
          pass
      if not _model and _npc and hasattr(_npc, 'resolved_model'):
          _model = _npc.resolved_model()
      if not _provider and _npc and hasattr(_npc, 'resolved_provider'):
          _provider = _npc.resolved_provider()

      # ── Discover available jinxes ─────────────────────────────────────────────
      def discover_jinxes(npc_obj, team_obj):
          found = {}
          if team_obj and hasattr(team_obj, 'jinxes_dict'):
              for name, jinx in team_obj.jinxes_dict.items():
                  if name == 'loop_plan':
                      continue
                  desc = getattr(jinx, 'description', '') or getattr(jinx, 'jinx_name', name)
                  found[name] = desc

          global_team = os.path.expanduser('~/.npcsh/npc_team')
          for root, dirs, files in os.walk(global_team):
              dirs[:] = [d for d in dirs if d not in {'__pycache__', '.git'}]
              for f in files:
                  if f.endswith('.jinx'):
                      path = os.path.join(root, f)
                      name = os.path.splitext(f)[0]
                      if name in found or name == 'loop_plan':
                          continue
                      try:
                          with open(path, 'r', errors='replace') as fh:
                              lines = fh.read().splitlines()
                          desc = ''
                          in_desc = False
                          for line in lines:
                              stripped = line.strip()
                              if stripped.startswith('description:'):
                                  in_desc = True
                                  desc = stripped.split('description:', 1)[1].strip().lstrip('|').strip()
                                  if desc:
                                      break
                              elif in_desc and (stripped.startswith('- ') or stripped.startswith('inputs:') or stripped.startswith('steps:')):
                                  break
                              elif in_desc:
                                  desc += ' ' + stripped
                          found[name] = desc or f"Jinx from {path}"
                      except Exception:
                          pass
          return found

      jinx_catalog = discover_jinxes(_npc, _team)
      if not jinx_catalog:
          context['output'] = "Error: no jinxes discovered."
          context['messages'] = _messages
          exit()

      catalog_text = '\n'.join(f"  - {name}: {desc[:120]}" for name, desc in sorted(jinx_catalog.items()))

      # ── Discover available NPCs for delegation ───────────────────────────────
      npc_catalog = {}
      if _team and hasattr(_team, 'npcs'):
          for name, npc_obj in _team.npcs.items():
              directive = getattr(npc_obj, 'primary_directive', '') or getattr(npc_obj, 'description', '') or name
              npc_catalog[name] = directive[:120]
      if _npc and hasattr(_npc, 'name') and _npc.name not in npc_catalog:
          npc_catalog[_npc.name] = getattr(_npc, 'primary_directive', '') or _npc.name

      npc_catalog_text = '\n'.join(f"  - @{name}: {desc}" for name, desc in sorted(npc_catalog.items())) if npc_catalog else "  (no specialist NPCs loaded)"

      # ── Helpers ──────────────────────────────────────────────────────────────
      def status(msg):
          print(colored(f"  [loop_plan] {msg}", "cyan"))

      def llm(prompt, temperature=0.3, **kwargs):
          result = get_llm_response(
              prompt,
              model=_model,
              provider=_provider,
              npc=_npc,
              temperature=temperature,
              **kwargs,
          )
          return str(result.get('response', '')) if isinstance(result, dict) else str(result)

      def llm_json(prompt, temperature=0.2, **kwargs):
          result = get_llm_response(prompt, model=_model, provider=_provider, npc=_npc, format="json", temperature=temperature, **kwargs)
          return result.get('response', {}) if isinstance(result, dict) else {}

      # ── Plan generation ────────────────────────────────────────────────────────
      status("Generating plan...")

      plan_example = """
        {
          "goal_restatement": "concise restatement",
          "uncertainties": ["list ambiguities to ask the user before continuing"],
          "steps": [
            {
              "id": 1,
              "description": "what this step does",
              "type": "jinx|delegate|agentic",
              "target": "exact_jinx_name or @npc_name or self",
              "inputs": {"key": "value"},
              "prompt": "prompt to use for agentic/delegate steps; for jinx this can be null",
              "risk": "safe|moderate|dangerous",
              "success_criteria": "how we know this step is done"
            }
          ],
          "expected_completion_checklist": ["item 1", "item 2"]
        }
      """

      plan_prompt = f"""
        You are a planning orchestrator for an NPC shell.

        The user wants:
          {goal}

        Available jinxes:
        {catalog_text}

        Available NPCs for delegation:
        {npc_catalog_text}

        Create a concrete execution plan. Each step must be one of:
          - invoke a jinx by exact name
          - delegate to a specialist NPC (@name)
          - run an agentic sub-loop using the LLM with auto_process_tool_calls=True

        Return ONLY JSON in this exact format:{plan_example}
        Use double quotes. Risk must be safe, moderate, or dangerous.
      """

      plan = llm_json(plan_prompt, temperature=0.2)
      if not isinstance(plan, dict):
          plan = {}

      uncertainties = plan.get('uncertainties', []) or []
      steps = plan.get('steps', []) or []

      if uncertainties and not steps:
          uncertainties_text = "\n            ".join(f"- {u}" for u in uncertainties)
          paused_message = f"""
            === PLANNING PAUSED: NEED USER INPUT ===

            Goal: {plan.get('goal_restatement', goal)}

            Uncertainties:
            {uncertainties_text}

            Resolve these and re-run loop_plan with a clearer goal.
          """
          context['output'] = paused_message
          context['messages'] = _messages
          exit()

      if not steps:
          context['output'] = "Plan created but contains no steps. Refine the goal and try again."
          context['messages'] = _messages
          exit()

      # ── Present plan ─────────────────────────────────────────────────────────
      print(colored("\n=== LOOP PLAN ===", "cyan", attrs=["bold"]))
      print(colored(f"Goal: {plan.get('goal_restatement', goal)}", "white", attrs=["dark"]))
      for s in steps:
          risk_tag = f"[{s.get('risk', 'safe').upper()}]"
          ttype = s.get('type', 'jinx')
          target = s.get('target', s.get('jinx', '?'))
          print(colored(f"  [{s['id']}] {s.get('description', '')} -> {ttype}:{target} {risk_tag}", "white"))
      print(colored("=================\n", "cyan", attrs=["bold"]))

      # Optional confirmation. In a headless run we proceed; the permission system
      # will gate dangerous individual tool calls anyway.
      if require_confirmation:
          status("require_confirmation=true but no interactive form available in this context; proceeding.")

      completion_checklist = plan.get('expected_completion_checklist', []) or []
      step_results = []
      action_count = 0
      checkpoint = {
          "goal": plan.get('goal_restatement', goal),
          "steps_completed": [],
          "steps_remaining": [s.get('description', f"Step {s['id']}") for s in steps],
          "findings": [],
          "errors": [],
      }

      # ── Execution loop ───────────────────────────────────────────────────────
      status("Entering execution loop...")

      for i, step in enumerate(steps):
          if action_count >= budget_actions:
              print(colored(f"\nAction budget ({budget_actions}) reached. Stopping.", "yellow", attrs=["bold"]))
              break

          iteration = i + 1
          if iteration > max_iters:
              print(colored(f"\nMax iterations ({max_iters}) reached. Stopping.", "yellow", attrs=["bold"]))
              break

          stype = step.get('type', 'jinx')
          target = step.get('target') or step.get('jinx', '')
          inputs = step.get('inputs', {}) or {}
          description = step.get('description', f"Step {iteration}")
          risk = step.get('risk', 'safe')
          step_prompt = step.get('prompt', '') or description

          action_count += 1

          print(colored(f"\n── Step {iteration}/{len(steps)} [{risk.upper()}] ──", "yellow", attrs=["bold"]))
          print(colored(f"  {description}", "white"))

          step_output = None
          step_error = None

          try:
              if stype == 'jinx':
                  jinx_name = target
                  if jinx_name not in jinx_catalog:
                      step_error = f"Jinx '{jinx_name}' not in catalog."
                  else:
                      print(colored(f"  Invoking /{jinx_name} inputs={json.dumps(inputs)}", "white", attrs=["dark"]))
                      if _npc and hasattr(_npc, 'execute_jinx'):
                          result = _npc.execute_jinx(
                              jinx_name=jinx_name,
                              inputs=inputs,
                              extra_globals={'state': _state, 'team': _team, 'npc': _npc}
                          )
                      else:
                          result = {"response": f"No NPC.execute_jinx available. Simulated /{jinx_name}."}
                      step_output = result.get('output') or result.get('response') or str(result) if isinstance(result, dict) else str(result)

              elif stype == 'delegate':
                  npc_name = target.lstrip('@')
                  if npc_name not in npc_catalog:
                      step_error = f"NPC '{npc_name}' not available for delegation."
                  else:
                      print(colored(f"  Delegating to @{npc_name}", "white", attrs=["dark"]))
                      delegate_npc = _team.npcs.get(npc_name) if _team and hasattr(_team, 'npcs') else None
                      if delegate_npc is None and _npc and getattr(_npc, 'name', None) == npc_name:
                          delegate_npc = _npc
                      if delegate_npc and hasattr(delegate_npc, 'get_llm_response'):
                          result = delegate_npc.get_llm_response(
                              step_prompt,
                              auto_process_tool_calls=True,
                              model=_model,
                              provider=_provider,
                              messages=_messages,
                          )
                      else:
                          result = get_llm_response(
                              step_prompt,
                              model=_model,
                              provider=_provider,
                              npc=delegate_npc or _npc,
                              messages=_messages,
                              auto_process_tool_calls=True,
                          )
                      step_output = result.get('response', '') if isinstance(result, dict) else str(result)

              elif stype == 'agentic':
                  print(colored("  Running agentic sub-loop with auto_process_tool_calls=True", "white", attrs=["dark"]))
                  result = get_llm_response(
                      step_prompt,
                      model=_model,
                      provider=_provider,
                      npc=_npc,
                      messages=_messages,
                      auto_process_tool_calls=True,
                  )
                  step_output = result.get('response', '') if isinstance(result, dict) else str(result)

              else:
                  step_error = f"Unknown step type '{stype}'."

          except Exception as e:
              step_error = f"{type(e).__name__}: {e}"
              traceback.print_exc()

          # Checkpoint after each step
          checkpoint["steps_completed"].append(description)
          if checkpoint["steps_remaining"]:
              checkpoint["steps_remaining"].pop(0)
          if step_error:
              checkpoint["errors"].append({"step": iteration, "error": step_error})
          else:
              checkpoint["findings"].append({"step": iteration, "summary": str(step_output)[:400]})

          step_results.append({
              "step": iteration,
              "type": stype,
              "target": target,
              "description": description,
              "status": "error" if step_error else "done",
              "output_preview": str(step_output)[:500] if step_output else "",
              "error": step_error,
          })

          # Progress report
          print(colored("\n  [PROGRESS REPORT]", "green", attrs=["bold"]))
          print(colored(f"    Completed: {len(checkpoint['steps_completed'])}/{len(steps)}", "white", attrs=["dark"]))
          print(colored(f"    Actions used: {action_count}/{budget_actions}", "white", attrs=["dark"]))
          if step_error:
              print(colored(f"    Last error: {step_error}", "red"))
          remaining = steps[i+1:]
          if remaining:
              print(colored(f"    Remaining: " + ", ".join(f"[{s['id']}] {s.get('target', s.get('jinx', '?'))}" for s in remaining), "white", attrs=["dark"]))

      # ── Completion review ─────────────────────────────────────────────────────
      status("Reviewing completion...")

      review_example = """
        {
          "completed_checklist": [
            {"item": "expected checklist item", "done": true, "evidence": "which step produced this"}
          ],
          "missing_items": ["things still needed"],
          "surface_level_only": false,
          "recommendation": "STOP|CONTINUE|NEEDS_USER_INPUT",
          "next_actions": ["optional next jinx invocations if CONTINUE"]
        }
      """

      review_prompt = f"""
        You are a completion reviewer for a multi-step NPC loop.

        Original goal: {goal}
        Plan restatement: {plan.get('goal_restatement', goal)}
        Expected checklist: {json.dumps(completion_checklist)}

        Checkpoint:
        {json.dumps(checkpoint, indent=2)}

        Step results:
        {json.dumps(step_results, indent=2)}

        Review the results and return ONLY JSON in this exact format:{review_example}
        surface_level_only should be true if the work stopped at exploration without implementation or verification.
        recommendation must be STOP, CONTINUE, or NEEDS_USER_INPUT.
      """

      review = llm_json(review_prompt, temperature=0.2)
      if not isinstance(review, dict):
          review = {
              "completed_checklist": [],
              "missing_items": ["Review response was not valid JSON."],
              "surface_level_only": False,
              "recommendation": "NEEDS_USER_INPUT",
              "next_actions": [],
          }

      # ── Final output ─────────────────────────────────────────────────────────
      completed_lines = "\n        ".join(
          f"{'[✓]' if item.get('done') else '[ ]'} {item.get('item', '')} — {item.get('evidence', '')}"
          for item in review.get('completed_checklist', [])
      )
      missing_section = (
          "\n\n        Still missing:\n        "
          + "\n        ".join(f"[ ] {m}" for m in review.get('missing_items', []))
      ) if review.get('missing_items') else ""
      warning_section = (
          "\n\n        WARNING: Execution looks surface-level. Re-run with a more specific goal or higher budget, or ask the user how to proceed."
      ) if review.get('surface_level_only') else ""
      next_section = (
          "\n\n        Suggested next actions:\n        "
          + "\n        ".join(f"- {a}" for a in review.get('next_actions', []))
      ) if review.get('next_actions') else ""
      checkpoint_text = "        " + json.dumps(checkpoint, indent=2).replace("\n", "\n        ")
      step_lines = "\n        ".join(
          f"[{'✓' if sr.get('status') == 'done' else '✗'}] Step {sr['step']} {sr['type']}:{sr['target']} - {sr['description']}"
          + (f"\n            Error: {sr['error']}" if sr.get('error') else "")
          for sr in step_results
      )

      final_output = f"""
        === LOOP PLAN RESULT ===
        Goal: {plan.get('goal_restatement', goal)}
        Steps attempted: {len(step_results)}/{len(steps)}
        Actions used: {action_count}/{budget_actions}
        Recommendation: {review.get('recommendation', 'UNKNOWN')}

        Completed checklist:
        {completed_lines}{missing_section}{warning_section}{next_section}

        Checkpoint:
        {checkpoint_text}

        Detailed step results:
        {step_lines}
      """

      print(colored("\n" + "="*60, "cyan"))
      print(colored("  LOOP PLAN COMPLETE", "cyan", attrs=["bold"]))
      print(colored("="*60, "cyan"))

      context['output'] = final_output
      context['messages'] = _messages
      context['loop_plan_result'] = {
          'goal': goal,
          'plan': plan,
          'step_results': step_results,
          'checkpoint': checkpoint,
          'completion_review': review,
          'actions_used': action_count,
          'budget_actions': budget_actions,
      }
