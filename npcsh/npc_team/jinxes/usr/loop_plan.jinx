permissions:
  default: ask
jinx_name: loop_plan
description: |
  Scope-lock and execute a multi-step task by planning which jinxes to invoke,
  then looping through them with progress reports, investigation-budget checks,
  and a completion checklist before finishing. Use for broad or ambiguous requests
  where the agent would otherwise stop at a surface-level fix.
inputs:
  - goal: null
  - max_iterations: "10"
  - budget_actions: "20"
  - require_confirmation: "false"
steps:
  - name: run_loop_plan
    engine: python
    code: |
      import json
      import os
      import sys
      import traceback
      from datetime import datetime

      from termcolor import colored
      from npcpy.llm_funcs import get_llm_response

      # ── Inputs ───────────────────────────────────────────────────────────────
      _npc = context.get('npc')
      _team = context.get('team')
      _messages = context.get('messages', [])

      goal = context.get('goal', '')
      if not goal:
          context['output'] = "Error: provide a goal=\"...\" for loop_plan."
          context['messages'] = _messages
          exit()

      max_iters = int(context.get('max_iterations') or '10')
      budget_actions = int(context.get('budget_actions') or '20')
      require_confirmation = str(context.get('require_confirmation', 'false')).lower() in ('true', '1', 'yes')

      # Use the shell's current model/provider — never let the LLM override these.
      _model = None
      _provider = None
      try:
          _model = state.chat_model
          _provider = state.chat_provider
      except Exception:
          pass
      if not _model and _npc and hasattr(_npc, 'model') and _npc.model:
          _model = _npc.model
      if not _provider and _npc and hasattr(_npc, 'provider') and _npc.provider:
          _provider = _npc.provider

      # ── Discover available jinxes ───────────────────────────────────────────
      def discover_jinxes(npc_obj, team_obj):
          """Return {name: description} for jinxes from team and global dirs."""
          found = {}

          # Team-loaded jinxes (already parsed)
          if team_obj and hasattr(team_obj, 'jinxes_dict'):
              for name, jinx in team_obj.jinxes_dict.items():
                  if name == 'loop_plan':
                      continue
                  desc = getattr(jinx, 'description', '') or getattr(jinx, 'jinx_name', name)
                  found[name] = desc

          # Also walk the global team directory on disk for anything not loaded
          global_team = os.path.expanduser('~/.npcsh/npc_team')
          for root, dirs, files in os.walk(global_team):
              dirs[:] = [d for d in dirs if d not in {'__pycache__', '.git'}]
              for f in files:
                  if f.endswith('.jinx'):
                      path = os.path.join(root, f)
                      name = os.path.splitext(f)[0]
                      if name in found or name == 'loop_plan':
                          continue
                      try:
                          # Quick YAML peek for description without full Jinja render
                          with open(path, 'r', errors='replace') as fh:
                              lines = fh.read().splitlines()
                          desc = ''
                          in_desc = False
                          for line in lines:
                              stripped = line.strip()
                              if stripped.startswith('description:'):
                                  in_desc = True
                                  desc = stripped.split('description:', 1)[1].strip().lstrip('|').strip()
                                  if desc:
                                      break
                              elif in_desc and (stripped.startswith('- ') or stripped.startswith('inputs:') or stripped.startswith('steps:')):
                                  break
                              elif in_desc:
                                  desc += ' ' + stripped
                          found[name] = desc or f"Jinx from {path}"
                      except Exception:
                          pass
          return found

      jinx_catalog = discover_jinxes(_npc, _team)
      if not jinx_catalog:
          context['output'] = "Error: no jinxes discovered in ~/.npcsh/npc_team or current team."
          context['messages'] = _messages
          exit()

      catalog_text = '\n'.join(f"  - {name}: {desc[:120]}" for name, desc in sorted(jinx_catalog.items()))

      # ── Helpers ──────────────────────────────────────────────────────────────
      def status(msg):
          print(colored(f"  [loop_plan] {msg}", "cyan"))

      def llm(prompt, temperature=0.3):
          result = get_llm_response(
              prompt,
              model=_model,
              provider=_provider,
              npc=_npc,
              temperature=temperature,
              thinking={'type': 'enabled', 'budget_tokens': 128},
          )
          return str(result.get('response', '')) if isinstance(result, dict) else str(result)

      def parse_json_block(text):
          text = text.strip()
          if '```json' in text:
              text = text.split('```json')[1].split('```')[0]
          elif '```' in text:
              text = text.split('```')[1].split('```')[0]
          return json.loads(text.strip())

      # ── Scope-locking: create plan with explicit jinx mapping ────────────────
      status("Scope-locking: creating plan...")
      plan_prompt = f"""You are a planning orchestrator for an NPC shell.

The user wants:
  {goal}

Available jinxes in ~/.npcsh/npc_team and the current team:
{catalog_text}

Create a concrete execution plan. Each step MUST invoke exactly one of the available jinxes above.
Do not invent jinxes. Prefer these patterns when appropriate:
  - /explore for codebase investigation
  - /plan for sub-planning
  - /delegate for handing work to a specialist NPC
  - /chat for LLM-only reasoning
  - /agent for tool-using autonomous work
  - /convene for multi-perspective discussion

Return ONLY JSON in this exact format:
{{
  "goal_restatement": "concise restatement of the user goal",
  "uncertainties": ["list any ambiguities you want the user to confirm before continuing"],
  "steps": [
    {{
      "id": 1,
      "description": "what this step does",
      "jinx": "exact_jinx_name",
      "inputs": {{"key": "value"}},
      "risk": "safe|moderate|dangerous",
      "success_criteria": "how we know this step is done"
    }}
  ],
  "expected_completion_checklist": ["item 1", "item 2"]
}}

If the goal is ambiguous and you need user input, set steps to [] and list uncertainties.
Use double quotes. Risk must be safe, moderate, or dangerous."""

      plan_text = llm(plan_prompt, temperature=0.2)
      try:
          plan = parse_json_block(plan_text)
      except Exception as e:
          context['output'] = f"Failed to parse plan JSON: {e}\n\nLLM response:\n{plan_text[:2000]}"
          context['messages'] = _messages
          exit()

      uncertainties = plan.get('uncertainties', [])
      steps = plan.get('steps', [])

      if uncertainties and not steps:
          context['output'] = (
              "=== PLANNING PAUSED: NEED USER INPUT ===\n\n"
              + f"Goal: {plan.get('goal_restatement', goal)}\n\n"
              + "Uncertainties:\n  - " + "\n  - ".join(uncertainties)
              + "\n\nResolve these and re-run /loop_plan with a clearer goal."
          )
          context['messages'] = _messages
          exit()

      if not steps:
          context['output'] = "Plan created but contains no steps. Refine the goal and try again."
          context['messages'] = _messages
          exit()

      # Print plan
      print(colored("\n=== LOOP PLAN ===", "cyan", attrs=["bold"]))
      print(colored(f"Goal: {plan.get('goal_restatement', goal)}", "white", attrs=["dark"]))
      for s in steps:
          risk_tag = f"[{s.get('risk', 'safe').upper()}]"
          print(colored(f"  [{s['id']}] {s.get('description', '')} -> /{s.get('jinx')} {risk_tag}", "white"))
      print(colored("=================\n", "cyan", attrs=["bold"]))

      if require_confirmation:
          print(colored("Confirm plan to continue (not implemented in non-interactive mode).", "yellow"))

      completion_checklist = plan.get('expected_completion_checklist', [])
      step_results = []
      action_count = 0
      completed_steps = 0

      # ── Execution loop ─────────────────────────────────────────────────────
      status("Entering execution loop...")

      for i, step in enumerate(steps):
          if action_count >= budget_actions:
              print(colored(f"\nInvestigation/action budget ({budget_actions}) reached. Stopping.", "yellow", attrs=["bold"]))
              break

          iteration = i + 1
          if iteration > max_iters:
              print(colored(f"\nMax iterations ({max_iters}) reached. Stopping.", "yellow", attrs=["bold"]))
              break

          jinx_name = step.get('jinx')
          inputs = step.get('inputs', {}) or {}
          description = step.get('description', f"Step {iteration}")
          risk = step.get('risk', 'safe')

          if jinx_name not in jinx_catalog:
              print(colored(f"  Step {iteration}: jinx '{jinx_name}' not available. Skipping.", "red"))
              step_results.append({"step": iteration, "jinx": jinx_name, "status": "skipped", "reason": "not in catalog"})
              continue

          action_count += 1

          print(colored(f"\n── Step {iteration}/{len(steps)} [{risk.upper()}] ──", "yellow", attrs=["bold"]))
          print(colored(f"  {description}", "white"))
          print(colored(f"  Invoking: /{jinx_name} inputs={json.dumps(inputs)}\n", "white", attrs=["dark"]))

          # Invoke the jinx
          step_output = None
          step_error = None
          try:
              if _npc and hasattr(_npc, 'execute_jinx'):
                  result = _npc.execute_jinx(
                      jinx_name=jinx_name,
                      inputs=inputs,
                      extra_globals={'state': context.get('state'), 'team': _team, 'npc': _npc}
                  )
              else:
                  # Fallback: ask the LLM to simulate what the jinx would do
                  result = {"response": f"No NPC.execute_jinx available. Simulated invocation of /{jinx_name} with {inputs}."}

              if isinstance(result, dict):
                  step_output = result.get('output') or result.get('response') or str(result)
              else:
                  step_output = str(result)
          except Exception as e:
              step_error = f"{type(e).__name__}: {e}"
              traceback.print_exc()

          completed_steps += 1 if not step_error else 0

          # Progress report gate after every step
          progress_lines = [
              f"Completed: {completed_steps}/{len(steps)} steps",
              f"Actions used: {action_count}/{budget_actions}",
          ]
          if step_error:
              progress_lines.append(f"Last step error: {step_error}")

          print(colored("\n  [PROGRESS REPORT]", "green", attrs=["bold"]))
          for line in progress_lines:
              print(colored(f"    {line}", "white", attrs=["dark"]))
          print(colored("  Remaining: " + ", ".join(s.get('jinx', '?') for s in steps[i+1:]), "white", attrs=["dark"]))

          step_results.append({
              "step": iteration,
              "jinx": jinx_name,
              "description": description,
              "status": "error" if step_error else "done",
              "output_preview": str(step_output)[:500] if step_output else "",
              "error": step_error,
          })

      # ── Diff / completion checklist before finalizing ───────────────────────
      status("Running completion checklist...")

      checklist_prompt = f"""You are a completion reviewer.

Original goal: {goal}
Plan restatement: {plan.get('goal_restatement', goal)}
Expected checklist: {json.dumps(completion_checklist)}

Steps executed:
{json.dumps(step_results, indent=2)}

Review the results and produce a final assessment. Return ONLY JSON:
{{
  "completed_checklist": [
    {{"item": "expected checklist item", "done": true, "evidence": "which step produced this"}}
  ],
  "missing_items": ["things still needed"],
  "surface_level_only": false,
  "recommendation": "STOP|CONTINUE|NEEDS_USER_INPUT",
  "next_actions": ["optional next jinx invocations if CONTINUE"]
}}

surface_level_only should be true if the results look like shallow exploration without real implementation.
recommendation must be STOP, CONTINUE, or NEEDS_USER_INPUT."""

      review_text = llm(checklist_prompt, temperature=0.2)
      try:
          review = parse_json_block(review_text)
      except Exception as e:
          review = {
              "completed_checklist": [],
              "missing_items": [f"Review JSON parse error: {e}"],
              "surface_level_only": False,
              "recommendation": "NEEDS_USER_INPUT",
              "next_actions": [],
          }

      # ── Final output ─────────────────────────────────────────────────────────
      summary_parts = [
          "=== LOOP PLAN RESULT ===",
          f"Goal: {plan.get('goal_restatement', goal)}",
          f"Steps attempted: {len(step_results)}/{len(steps)}",
          f"Actions used: {action_count}/{budget_actions}",
          f"Recommendation: {review.get('recommendation', 'UNKNOWN')}",
          "",
          "Completed checklist:",
      ]
      for item in review.get('completed_checklist', []):
          mark = "[✓]" if item.get('done') else "[ ]"
          summary_parts.append(f"  {mark} {item.get('item', '')} — {item.get('evidence', '')}")

      missing = review.get('missing_items', [])
      if missing:
          summary_parts.extend(["", "Still missing:"])
          for m in missing:
              summary_parts.append(f"  [ ] {m}")

      if review.get('surface_level_only'):
          summary_parts.extend(["", "WARNING: Execution looks surface-level. Consider re-running with a more specific goal or higher budget."])

      next_actions = review.get('next_actions', [])
      if next_actions:
          summary_parts.extend(["", "Suggested next actions:"])
          for a in next_actions:
              summary_parts.append(f"  - {a}")

      summary_parts.append("\nDetailed step results:")
      for sr in step_results:
          icon = "✓" if sr.get('status') == 'done' else "✗"
          summary_parts.append(f"  [{icon}] Step {sr['step']} /{sr['jinx']}: {sr['description']}")
          if sr.get('error'):
              summary_parts.append(f"      Error: {sr['error']}")

      final_output = "\n".join(summary_parts)

      print(colored("\n" + "="*60, "cyan"))
      print(colored("  LOOP PLAN COMPLETE", "cyan", attrs=["bold"]))
      print(colored("="*60, "cyan"))

      context['output'] = final_output
      context['messages'] = _messages
      context['loop_plan_result'] = {
          'goal': goal,
          'plan': plan,
          'step_results': step_results,
          'completion_review': review,
          'actions_used': action_count,
          'budget_actions': budget_actions,
      }
